{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "chrome",
      "request": "launch",
      "name": "VISORA: Chrome (Next.js dev)",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/visora"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "VISORA: Next.js server",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/visora",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**"]
    }
  ],
  "compounds": [
    {
      "name": "VISORA: Full stack",
      "configurations": ["VISORA: Next.js server", "VISORA: Chrome (Next.js dev)"],
      "stopAll": true
    }
  ]
}

{
  "version": "0.2.0",
  "configurations": [
    {
      "type": "node-terminal",
      "request": "launch",
      "name": "VISORA: Dev server",
      "command": "npm run dev",
      "cwd": "${workspaceFolder}/visora"
    },
    {
      "type": "node",
      "request": "launch",
      "name": "VISORA: Dev server (inspect)",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev:debug"],
      "cwd": "${workspaceFolder}/visora",
      "console": "integratedTerminal",
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "type": "node",
      "request": "attach",
      "name": "VISORA: Attach to Node (9229)",
      "port": 9229,
      "skipFiles": ["<node_internals>/**", "**/node_modules/**"]
    },
    {
      "type": "chrome",
      "request": "launch",
      "name": "VISORA: Chrome (client)",
      "url": "http://localhost:3000",
      "webRoot": "${workspaceFolder}/visora"
    }
  ],
  "compounds": [
    {
      "name": "VISORA: Full stack debug",
      "configurations": [
        "VISORA: Dev server (inspect)",
        "VISORA: Chrome (client)"
      ],
      "stopAll": true,
      "presentation": {
        "order": 1
      }
    }
  ]
}

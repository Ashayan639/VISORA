# ─────────────────────────────────────────────────────────────
# VISORA — Environment variable template
#
# Copy this file to `.env.local` and fill in the values you need.
# `.env.local` is gitignored — never commit it.
#
# VISORA degrades safely on every missing key:
#   - No FAL_KEY        → demo mode renders /api/placeholder SVGs.
#   - No OPENAI_API_KEY → brand generation falls back to templates.
#   - No Supabase keys  → projects persist to localStorage instead.
#   - No OAuth secrets  → the matching sign-in button is hidden.
#
# So the app runs end-to-end with an empty .env.local — every key
# below is OPTIONAL but unlocks more of the stack as you fill it in.
# ─────────────────────────────────────────────────────────────


# ─── Required for live AI generation (server-side only) ─────────

# fal.ai — https://fal.ai/dashboard/keys
# Powers /api/generate-visual, /api/generate-all-visuals, /api/generate-3d.
FAL_KEY=

# OpenAI — https://platform.openai.com/api-keys
# Powers /api/generate-brand. Without it, brands use a templated fallback.
OPENAI_API_KEY=


# ─── Supabase — projects, gallery, session adapter ──────────────

# Public (safe in the browser).
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Service role — server-only, bypasses RLS. NEVER expose to the browser.
SUPABASE_SERVICE_ROLE_KEY=


# ─── NextAuth ──────────────────────────────────────────────────

# Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
NEXTAUTH_SECRET=

# Local dev: http://localhost:3000  ·  Production: your canonical site URL.
NEXTAUTH_URL=http://localhost:3000


# ─── Google OAuth ──────────────────────────────────────────────
# https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=


# ─── Optional: GitHub OAuth ────────────────────────────────────
# https://github.com/settings/developers
# Leave blank to disable the "Sign in with GitHub" button.
GITHUB_ID=
GITHUB_SECRET=

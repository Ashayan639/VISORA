# ─────────────────────────────────────────────────────────────
# VISORA — Environment variable template
# Copy to `.env.local` and fill in values. Never commit `.env.local`.
# ─────────────────────────────────────────────────────────────

FAL_KEY=
OPENAI_API_KEY=

# Supabase (required for auth + optional gallery persistence)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# OAuth redirect fallback (match the port you use for `npm run dev`)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ── Google sign-in (Supabase — NOT set in this file) ─────────
# 1. Supabase Dashboard → Authentication → Providers → Google
#    Paste Client ID + Secret from Google Cloud Console
# 2. Supabase → Authentication → URL Configuration
#    Site URL: http://localhost:3000
#    Redirect URLs: http://localhost:3000/auth/callback
# 3. Google Cloud → OAuth client → Authorized redirect URI:
#    https://YOUR_PROJECT_REF.supabase.co/auth/v1/callback

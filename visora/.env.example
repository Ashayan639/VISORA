# ─────────────────────────────────────────────────────────────
# VISORA — Environment variable template
# Copy this file to `.env.local` and fill in the values.
# Do NOT commit `.env.local`.
# ─────────────────────────────────────────────────────────────

# fal.ai (server-side only) — https://fal.ai/dashboard/keys
FAL_KEY=

# OpenAI (server-side only) — https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Google Gemini (server-side only) — https://aistudio.google.com/apikey
GOOGLE_GENERATIVE_AI_API_KEY=

# Supabase (URL + anon key are safe in the browser)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase service role (server-side only — bypasses RLS, never expose)
SUPABASE_SERVICE_ROLE_KEY=

# NextAuth — generate with: `node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"`
NEXTAUTH_SECRET=
NEXTAUTH_URL=http://localhost:3000

# Google OAuth — https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
